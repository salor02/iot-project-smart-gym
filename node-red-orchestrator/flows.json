    {
        "id": "214fa20d09b458b3",
        "type": "function",
        "z": "a3bf68ef45bf6a78",
        "name": "recorded exercises history",
        "func": "let history = flow.get(\"exercise_history\") || [];\n\nif(msg.payload == \"\"){\n    flow.set(\"exercise_history\", null);\n    return msg;\n}\n\nlet video_name = msg.payload.rec_path.split(\"/\").pop();\n\nlet heat_index = global.get(\"heat_index\");\n\n// MET values are estimated based on resistance training standards\nlet exercise = msg.payload.exercise;\nlet met_value = 0;\nif (exercise === \"Squat\") {\n    met_value = 5.0;  // High compound movement, heavy systemic load\n} else if (exercise === \"Romanian Deadlift\") {\n    met_value = 4.5;  // Heavy posterior chain compound movement\n} else if (exercise === \"Lateral Raise\") {\n    met_value = 2.5;  // Small muscle isolation, low systemic load\n} else if (exercise === \"Bicep Curl\") {\n    met_value = 2.8;  // Small muscle isolation, slightly higher load than lateral raises\n}\n\nlet fatique_multiplier = 1.0 + (Math.sqrt(msg.payload.reps) - 1.0) * 0.5;\nlet stress_index = (heat_index * met_value * fatique_multiplier) / 4.8;\nnode.warn(met_value);\n\nlet incoming = {\n    \"time\": msg.payload.timestamp,\n    \"exercise\": msg.payload.exercise,\n    \"reps\": msg.payload.reps,\n    \"stress_index\": Math.round(stress_index),\n    \"rec_url\": \"http://192.168.1.253:1880/recordings/\"+video_name\n};\n\n// Update the first row if the received payload is relative to the current exercise\nif (history.length > 0 && history[0].exercise === incoming.exercise && history[0].reps < incoming.reps) {\n    history[0].reps = incoming.reps;\n    history[0].stress_index = incoming.stress_index;\n} else {\n    history.unshift(incoming);\n\n    if (history.length > 20) {\n        history = history.slice(0, 20);\n    }\n}\n\nflow.set(\"exercise_history\", history);\nmsg.payload = history;\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
