    {
        "id": "d6d109f47b0b4411",
        "type": "function",
        "z": "752b30f9dfdda7b1",
        "name": "calc heat index",
        "func": "let temp = msg.payload.temp;\nlet hum = msg.payload.humidity;\n\n// The NOAA Rothfusz regression equation requires temperature in Fahrenheit\nlet tempF = (temp * 9/5) + 32;\n\n// Calculate the Apparent Temperature (Heat Index)\nlet heatIndexF = 0;\n\n// First, compute the simple Heat Index (used for lower temperatures)\nlet simpleHI = 0.5 * (tempF + 61.0 + ((tempF - 68.0) * 1.2) + (hum * 0.094));\n\n// If the simple Heat Index is 80°F (about 27°C) or higher, use the full Rothfusz regression equation\n// see https://www.wpc.ncep.noaa.gov/html/heatindex_equation.shtml\nif (simpleHI >= 80) {\n    heatIndexF = -42.379 + (2.04901523 * tempF) + (10.14333127 * hum) \n        - (0.22475541 * tempF * hum) - (0.00683783 * tempF * tempF) \n        - (0.05481717 * hum * hum) + (0.00122874 * tempF * tempF * hum) \n        + (0.00085282 * tempF * hum * hum) - (0.00000199 * tempF * tempF * hum * hum);\n    \n    // Adjustments based on specific humidity and temperature ranges\n    if (hum < 13 && tempF >= 80 && tempF <= 112) {\n        let adjustment = ((13 - hum) / 4) * Math.sqrt((17 - Math.abs(tempF - 95)) / 17);\n        heatIndexF -= adjustment;\n    } else if (hum > 85 && tempF >= 80 && tempF <= 87) {\n        let adjustment = ((hum - 85) / 10) * ((87 - tempF) / 5);\n        heatIndexF += adjustment;\n    }\n} else {\n    // For cooler environments (like a winter garage), the simple formula is sufficient\n    heatIndexF = simpleHI;\n}\n\n// Convert back to Celsius for dashboard visualization\nlet heatIndexC = ((heatIndexF - 32) * 5/9).toFixed(2); \n\nglobal.set(\"heat_index\", heatIndexC);\n\nvar actual_temp = {\n    payload: temp,\n    topic: \"Actual Temperature\"\n};\n\nvar feels_like = {\n    payload: heatIndexC,\n    topic: \"Feels Like\"\n};\n\nreturn [[actual_temp, feels_like]];\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 180,
