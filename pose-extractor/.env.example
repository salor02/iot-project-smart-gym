# HTTP stream URL from camera
STREAM_URL=http://192.168.1.23/stream

# MQTT broker host or IP
MQTT_BROKER=192.168.1.23

# MQTT broker port
MQTT_PORT=1883

# MQTT topic for start/stop commands
MQTT_TOPIC=vision/cmd

# Path to MediaPipe model file inside container/project
MODEL_PATH=/app/pose_landmarker_full.task

# Output folder for recordings
OUTPUT_DIR=/app/recordings

# Output video frames per second
OUTPUT_FPS=15

# Enable OpenCV preview window (1=true, 0=false)
ENABLE_PREVIEW=1
